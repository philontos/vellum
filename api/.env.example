# === Chat model (any OpenAI-compatible /chat/completions endpoint) ===
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# === Embedding (OpenAI-compatible /embeddings) ===
# Falls back to LLM_* if unset — set explicitly when your chat provider has no embeddings (DeepSeek/Claude/Moonshot).
EMBED_BASE_URL=http://localhost:11434/v1
EMBED_API_KEY=ollama
EMBED_MODEL=bge-m3

# Common base URLs (copy into LLM_BASE_URL / EMBED_BASE_URL):
#   OpenAI    https://api.openai.com/v1                          (chat + embeddings)
#   DeepSeek  https://api.deepseek.com                           (chat only, no embeddings)
#   GLM       https://open.bigmodel.cn/api/paas/v4
#   Qwen      https://dashscope.aliyuncs.com/compatible-mode/v1
#   Gemini    https://generativelanguage.googleapis.com/v1beta/openai
#   Ollama    http://localhost:11434/v1                          (local, free)

# === Web search (optional) ===
# Off by default. Set a provider AND its key and the chat model gains a
# `web_search` tool it calls on its own — to ground specific companies/roles/
# technologies it doesn't know, or to pull in current/outside information. It is
# told to cross-check sources, distinguish fact from opinion, and cite inline.
# WEB_SEARCH_PROVIDER=tavily       # "" (disabled) | tavily
# TAVILY_API_KEY=tvly-...          # https://tavily.com — free tier ~1000/mo
# WEB_SEARCH_MAX_RESULTS=5
# WEB_SEARCH_DEPTH=basic           # basic (fast snippets) | advanced (deeper + page text)
# WEB_SEARCH_MAX_HOPS=4            # tool-loop rounds allowed when web search is on

# === Feishu / Lark chat (optional) ===
# Talk to vellum from the Feishu app over an official WebSocket long connection
# (no public URL/webhook needed — the server dials out). Off until BOTH values
# are set; then the API process also runs a Feishu bot answering your private
# chats. Use a custom app in YOUR OWN Feishu tenant (not your employer's) so no
# admin/colleague can see the conversation.
#   1. open.feishu.cn → 开发者后台 → 创建企业自建应用
#   2. 添加应用能力 → 机器人
#   3. 权限管理 → 开通 im:message  (收/发消息)
#   4. 事件订阅 → 选「使用长连接接收事件」→ 添加事件 接收消息 im.message.receive_v1
#   5. 复制 App ID / App Secret 到下面，发布版本，把机器人加为联系人
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx

# Data location (sqlite db + vector index)
VELLUM_DATA_DIR=./data

# === At-rest encryption (optional) ===
# Whole-database SQLCipher encryption (AES-256). Opt-in: set a 256-bit key as 64
# hex chars and every on-disk db is encrypted; leave it unset and the app runs in
# plaintext exactly as before. Requires the sqlcipher3 driver (see requirements.txt).
#   1. Generate a key (printed ONCE, never saved):   python -m app.keygen
#   2. Keep it OUTSIDE this data dir (password manager / key file). No backdoor:
#      lose it and the data is unrecoverable.
#   3. Encrypt an existing plaintext db in place:     python -m app.encrypt_db
# VELLUM_DB_KEY=<64-hex>
# VELLUM_DB_KEY_FILE=/path/to/key.hex   # alternative: read the key from a file (env wins)

# === Multi-device sync (optional) ===
# Move the encrypted db between devices over a git remote (a private repo is
# recommended; the remote only ever sees ciphertext). One active device at a time.
#   push:  python -m app.sync push      pull:  python -m app.sync pull      status
# VELLUM_SYNC_REMOTE=git@github.com:you/vellum-data.git
# VELLUM_DEVICE_ID=laptop               # optional label used as the git commit author

# Eval framework (only needed to RUN evals; harness tests are keyless):
# external evaluator model — a DIFFERENT model from LLM_MODEL is recommended
# (a model grading itself is less trustworthy), but the same model is allowed
# with a warning.
EVAL_GEN_BASE_URL=https://api.openai.com/v1
EVAL_GEN_API_KEY=
EVAL_GEN_MODEL=gpt-4.1
