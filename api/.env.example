# === Chat model (any OpenAI-compatible /chat/completions endpoint) ===
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# === Embedding (OpenAI-compatible /embeddings) ===
# Falls back to LLM_* if unset — set explicitly when your chat provider has no embeddings (DeepSeek/Claude/Moonshot).
EMBED_BASE_URL=http://localhost:11434/v1
EMBED_API_KEY=ollama
EMBED_MODEL=bge-m3

# Common base URLs (copy into LLM_BASE_URL / EMBED_BASE_URL):
#   OpenAI    https://api.openai.com/v1                          (chat + embeddings)
#   DeepSeek  https://api.deepseek.com                           (chat only, no embeddings)
#   GLM       https://open.bigmodel.cn/api/paas/v4
#   Qwen      https://dashscope.aliyuncs.com/compatible-mode/v1
#   Gemini    https://generativelanguage.googleapis.com/v1beta/openai
#   Ollama    http://localhost:11434/v1                          (local, free)

# Data location (sqlite db + vector index)
VELLUM_DATA_DIR=./data

# Eval framework (only needed to RUN evals; harness tests are keyless):
# external evaluator model — a DIFFERENT model from LLM_MODEL is recommended
# (a model grading itself is less trustworthy), but the same model is allowed
# with a warning.
EVAL_GEN_BASE_URL=https://api.openai.com/v1
EVAL_GEN_API_KEY=
EVAL_GEN_MODEL=gpt-4.1
